# ─── JARVIS Personal Health OS — Environment Variables ───────────────────────
# Copy this to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# SQLite database path
# Local dev: leave empty (defaults to ./health.db)
# Docker/EC2: set to /data/health.db
DB_PATH=

# OpenAI API key (for AI briefings + anomaly detection)
OPENAI_API_KEY=sk-proj-...

# Telegram Bot token (from @BotFather)
TELEGRAM_TOKEN=

# Node environment
NODE_ENV=development
